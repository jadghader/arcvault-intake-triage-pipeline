# n8n Workflow — environment variables
# These are read by the n8n Output nodes at runtime.
# Set them before starting n8n, or update the node URLs directly in the canvas.

# Groq API key (free tier — get one at console.groq.com)
# Used as the Authorization header value in the Groq API credential inside n8n.
# Format: Bearer gsk_...
# Note: this is set inside n8n Credentials UI, not read from this file directly.
GROQ_API_KEY=gsk_...

# Webhook.site — get your unique URL at https://webhook.site (no account needed)
WEBHOOK_SITE_URL=https://webhook.site/your-uuid-here

# Google Sheets — paste the sheet ID from your sheet URL:
# https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit
GOOGLE_SHEET_ID=your-sheet-id-here
