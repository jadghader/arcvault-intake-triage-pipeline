# ── LLM API Keys ─────────────────────────────────────────────────────────────
# At least one required. The backend exposes only models whose key is present.

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...
MISTRAL_API_KEY=...

# ── Backend ───────────────────────────────────────────────────────────────────
# Output directory for JSON + Excel (relative to repo root)
OUTPUT_DIR=data/outputs

# ── n8n (optional — for webhook testing) ─────────────────────────────────────
N8N_WEBHOOK_URL=http://localhost:5678/webhook/arcvault-intake
