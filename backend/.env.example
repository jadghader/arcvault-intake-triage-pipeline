# Backend (FastAPI + CLI) — environment variables
# Copy to the repo root as .env:
#   cp backend/.env.example .env
#
# The FastAPI app and CLI runner both load .env from the repo root.
# Only providers with a key set will appear in the web app model dropdown.

# ── LLM providers ─────────────────────────────────────────────────────────────
# CLI runner requires: pip install openai python-dotenv
# FastAPI app requires: pip install -r requirements.txt

# Groq (free tier — https://console.groq.com) — used by CLI runner + n8n workflow
GROQ_API_KEY=gsk_...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI
OPENAI_API_KEY=sk-...

# Mistral
MISTRAL_API_KEY=...

# Ollama: no key needed — runs locally, always listed in the dropdown.

# ── Output ────────────────────────────────────────────────────────────────────

# Directory where processed_records.json and .xlsx are written (relative to repo root)
OUTPUT_DIR=data/outputs
